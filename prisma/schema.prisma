generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ContactMessage {
  id        String   @id @default(cuid())

  nom       String
  email     String
  telephone String

  ville     String?
  projet    String?
  interet   String?
  message   String?

  vousEtes  String?
  consent   Boolean  @default(false)

  createdAt DateTime @default(now())
}

model InvestirDemande {
  id        String   @id @default(cuid())

  nom       String
  email     String
  telephone String
  ville     String?

  profil    String?
  budget    String?
  objectif  String?
  delai     String?

  message   String?
  consent   Boolean  @default(false)

  createdAt DateTime @default(now())
}


model ProjectLead {
  id        String   @id @default(cuid())

  nom       String
  email     String
  telephone String

  brand     String?
  ville     String?
  type      String?

  createdAt DateTime @default(now())
}

model ActualitesLead {
  id        String   @id @default(cuid())

  nom       String
  email     String
  telephone String?
  sujet     String?

  createdAt DateTime @default(now())
}